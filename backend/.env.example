# Deployment Doctor — Backend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ───────────────────────────────────────────────────────────────────
# Standard PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://deploymentdoctor:yourpassword@localhost:5432/deployment_doctor

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for development
CORS_ORIGINS=*

# ── Engine ────────────────────────────────────────────────────────────────────
ENGINE_VERSION=1.6.0
BLUEPRINT_VERSION=1.0.0

# ── AI Summary (optional) ─────────────────────────────────────────────────────
# OpenRouter API key — https://openrouter.ai/keys
# Leave blank to use the deterministic fallback summary (fully functional without this).
OPENROUTER_API_KEY=
